{
  "game": {
    "title": "Hitman 2: Silent Assassin",
    "originalExe": "hitman2.exe"
  },
  "optionGroups": [
    {
      "name": "Resolution",
      "type": "radioGroup",
      "radios": [
        { "value": "1280x800 (16/10)" },
        { "value": "1920x1080 (16/9)" },
        { "value": "2560x1440 (16/9)" },
        { "value": "3840x2160 (16/9)" },
        { "value": "2560x1080 (21/9)" },
        { "value": "3440x1440 (21/9)" },
        { "value": "5120x2160 (21/9)" },
        { "value": "3840x1080 (32/9)" },
        { "value": "5120x1440 (32/9)" },
        { "value": "7680x2160 (32/9)" },
        { "value": "Other (manually edit scripts\\h2.ini)" }
      ]
    },
    {
      "name": "UI Scaling",
      "type": "radioGroup",
      "radios": [
        { "value": "x1 (default)" },
        { "value": "x1.33 ~ x1.5", "disabledWhen": [ { "*Resolution": "Other" }, { "!Window Mode": "Exclusive Fullscreen" } ] },
        { "value": "x2", "disabledWhen": [ { "Resolution": "1280x800 (16/10)" }, { "!Window Mode": "Exclusive Fullscreen" } ] }
      ]
    },
    {
      "name": "Window Mode",
      "type": "radioGroup",
      "radios": [
        { "value": "Exclusive Fullscreen" },
        { "value": "Borderless Windowed Fullscreen", "disabledWhen": [ { "!UI Scaling": "x1 (default)" } ] },
        { "value": "Windowed", "disabledWhen": [ { "!UI Scaling": "x1 (default)" } ] }
      ]
    },
    {
      "name": "FOV Modifier",
      "type": "radioGroup",
      "radios": [
        { "value": "Lowest (-20%)" },
        { "value": "Lower (-10%)" },
        { "value": "Default" },
        { "value": "Higher (+10%)" },
        { "value": "Highest (+20%)" }
      ]
    },
    {
      "name": "Controller Options",
      "type": "radioGroup",
      "radios": [
        { "value": "Keyboard && Mouse" },
        { "value": "Controller (Xinput)" }
      ]
    },
    {
      "name": "Misc",
      "type": "checkboxGroup",
      "checkboxes": [
        { "value": "Skip intro videos" }
      ]
    }
  ],
