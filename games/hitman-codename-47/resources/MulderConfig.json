{
  "game": {
    "title": "Hitman: Codename 47",
    "originalExe": "Hitman.exe"
  },
  "optionGroups": [
    {
      "name": "Resolution",
      "type": "radioGroup",
      "radios": [
        { "value": "Desktop (automatic)" },
        { "value": "1280x800 (16/10)" },
        { "value": "1920x1080 (16/9)" },
        { "value": "2560x1440 (16/9)" },
        { "value": "3840x2160 (16/9)" },
        { "value": "2560x1080 (21/9)" },
        { "value": "3440x1440 (21/9)" },
        { "value": "5120x2160 (21/9)" },
        { "value": "3840x1080 (32/9)" },
        { "value": "5120x1440 (32/9)" },
        { "value": "7680x2160 (32/9)" },
        { "value": "Other (manually edit scripts\\HitmanCodename47WidescreenFix.ini)" }
      ]
    },
    {
      "name": "UI Scaling (Direct3D only)",
      "type": "radioGroup",
      "radios": [
        { "value": "x1 (default)" },
        { "value": "x2", "disabledWhen": [ { "Resolution": "Desktop (automatic)" }, { "!Window Mode": "Exclusive Fullscreen" } ] },
        { "value": "x3", "disabledWhen": [ { "Resolution": "Desktop (automatic)" }, { "*Resolution": "x800" }, { "*Resolution": "x1080" }, { "*Resolution": "x1440" }, { "*Resolution": "5120x" }, { "!Window Mode": "Exclusive Fullscreen" } ] },
      ]
    },
    {
      "name": "Window Mode",
      "type": "radioGroup",
      "radios": [
        { "value": "Exclusive Fullscreen" },
        { "value": "Borderless Windowed Fullscreen (Direct3D only)", "disabledWhen": [ { "!UI Scaling (Direct3D only)": "x1 (default)" } ] },
        { "value": "Windowed", "disabledWhen": [ { "!UI Scaling (Direct3D only)": "x1 (default)" } ] }
      ]
    },
    {
      "name": "FOV Modifier",
      "type": "radioGroup",
      "radios": [
        { "value": "Lowest (-20%)" },
        { "value": "Lower (-10%)" },
        { "value": "Default" },
        { "value": "Higher (+10%)" },
        { "value": "Highest (+20%)" }
      ]
    },
    {
      "name": "Draw Distance",
      "type": "radioGroup",
      "radios": [
        { "value": "Default (original)" },
        { "value": "Increase +15%" },
        { "value": "Increase +30%" }
      ]
    },
    {
      "name": "Misc",
      "type": "checkboxGroup",
      "checkboxes": [
        { "value": "Skip Intro Video" }
      ]
    }
  ],
